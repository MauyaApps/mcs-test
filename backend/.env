# ============================================
# MCS Backend - Environment Variables
# ============================================

# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# CORS (все нужные адреса)
CORS_ORIGIN=http://localhost,http://localhost:5173,http://192.168.0.106,http://192.168.0.106:5173,http://127.0.0.1:5173

# PostgreSQL Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mcs_db
DATABASE_USER=mcs_user
DATABASE_PASSWORD=mcs_secure_password_2024

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets
JWT_SECRET=mcs_jwt_super_secret_key_change_in_production_12345
JWT_REFRESH_SECRET=mcs_jwt_refresh_super_secret_key_change_in_production_67890
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=900
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION=900

# Logging
LOG_LEVEL=info
